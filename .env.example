# Automation Factory - Environment Configuration
# Copy this file to .env.local and fill in your actual values

# ============================================
# Node Environment
# ============================================
NODE_ENV=development

# ============================================
# Server Configuration
# ============================================
API_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/automation_factory

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=60000
DB_CONNECTION_TIMEOUT_MS=10000
DB_SSL_ENABLED=false

# ============================================
# Redis Configuration (for job queue)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# ============================================
# LLM Configuration (Ollama + Gemma 4)
# ============================================
# Ollama server URL (local or remote)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (must be pulled via: ollama pull gemma4:latest)
OLLAMA_MODEL=gemma4:latest

# Timeout for LLM requests (milliseconds)
OLLAMA_TIMEOUT_MS=300000

# Maximum tokens per request
OLLAMA_MAX_TOKENS=4096

# ============================================
# Tool Integration Secrets
# ============================================
# Slack webhook URL for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SendGrid API key for email sending
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE

# Zendesk API key for support ticket integration
ZENDESK_API_KEY=YOUR_ZENDESK_API_KEY_HERE

# ============================================
# Security Configuration
# ============================================
# CORS allowed origins (comma-separated or * for all)
CORS_ORIGIN=http://localhost:3000

# ============================================
# Logging Configuration
# ============================================
# Log level: error, warn, info, debug
LOG_LEVEL=info
